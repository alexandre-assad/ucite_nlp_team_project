{
  "model_id": "M2b",
  "description": "Arc-Standard + Static Oracle + FastText Word Embeddings + POS Embeddings + Dependency Label Embeddings + MLP + Greedy Decoding",
  "transition_system": "arc-standard",
  "oracle": "static",
  "features": "dense rich embeddings",
  "decoder": "greedy",
  "epochs": 10,
  "seed": 0,
  "train_path": "data/fr_gsd-ud-train.conllu",
  "dev_path": "data/fr_gsd-ud-dev.conllu",
  "test_path": "data/fr_gsd-ud-test.conllu",
  "output_dir": "experiments/m2b_arc_standard_dense_rich",
  "embedding": {
    "source": "fasttext_bin",
    "path": "data/embeddings/cc.fr.300.bin",
    "embedding_dim": 300,
    "oov_strategy": "fasttext_subword_vector",
    "seed": 0
  },
  "classifier": {
    "type": "mlp",
    "pos_embedding_dim": 32,
    "label_embedding_dim": 32,
    "hidden_dim": 512,
    "dropout": 0.2
  },
  "training": {
    "batch_size": 256,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "optimizer": "AdamW",
    "loss": "CrossEntropyLoss",
    "use_gpu_if_available": true
  }
}
